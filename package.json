{
  "name": "mod8-cli",
  "version": "0.5.29",
  "description": "The AI coding terminal that picks the best model for you. mod8 routes each task to Claude, GPT, Gemini, or DeepSeek — compares them side-by-side, switches mid-task, and ships sites with one command.",
  "type": "module",
  "bin": {
    "mod8": "./bin/mod8.js"
  },
  "files": [
    "bin",
    "dist",
    "specs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "verify": "node ./bin/mod8.js verify",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "cli",
    "llm",
    "ai",
    "chat",
    "byok",
    "claude",
    "anthropic",
    "openai",
    "gpt",
    "gemini",
    "google",
    "deepseek",
    "mistral",
    "groq",
    "openrouter",
    "xai",
    "grok",
    "together",
    "compare",
    "openai-compatible"
  ],
  "license": "MIT",
  "author": "mod8 <contact@mod8.ai> (https://mod8.ai)",
  "homepage": "https://mod8.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mod8-ai/mod8-cli.git"
  },
  "bugs": {
    "url": "https://github.com/mod8-ai/mod8-cli/issues"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.76",
    "@ai-sdk/google": "^3.0.72",
    "@ai-sdk/openai": "^3.0.63",
    "@ai-sdk/openai-compatible": "^2.0.47",
    "@anthropic-ai/sdk": "^0.94.0",
    "@google/generative-ai": "^0.24.1",
    "ai": "^6.0.177",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "diff": "^9.0.0",
    "ink": "^7.0.2",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.1.1",
    "openai": "^6.36.0",
    "react": "^19.2.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
