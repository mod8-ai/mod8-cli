{
  "name": "mod8",
  "version": "0.1.0",
  "description": "Talk to any LLM from your terminal — Claude, GPT, Gemini, DeepSeek, Mistral, Groq, anything OpenAI-compatible. BYOK.",
  "type": "module",
  "bin": {
    "mod8": "./bin/mod8.js"
  },
  "files": [
    "bin",
    "dist",
    "specs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "verify": "node ./bin/mod8.js verify",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "cli",
    "llm",
    "ai",
    "chat",
    "byok",
    "claude",
    "anthropic",
    "openai",
    "gpt",
    "gemini",
    "google",
    "deepseek",
    "mistral",
    "groq",
    "openrouter",
    "xai",
    "grok",
    "together",
    "compare",
    "openai-compatible"
  ],
  "license": "MIT",
  "author": "Yonatan Zlit",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.94.0",
    "@google/generative-ai": "^0.24.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ink": "^7.0.2",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.1.1",
    "openai": "^6.36.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
